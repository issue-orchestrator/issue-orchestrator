{"type":"item.completed","item":{"id":"item_42","type":"command_execution","command":"/bin/zsh -lc \"sed -n '110,160p' api-server/src/main/kotlin/com/tixmeup/api/EventIntelligenceService.kt\"","aggregated_output":"\n    private suspend fun loadIntelligence(\n        performanceId: PerformanceId,\n        now: Instant,\n    ) = runtimeObservability.traceSpan(\n        name = \"event_intelligence.evaluate_signals\",\n        stringAttributes = mapOf(\"tixmeup.performance_id\" to performanceId.value),\n    ) {\n        dependencies.signalEvaluationService.evaluate(\n            SignalEvaluationRequest(\n                performanceId = performanceId,\n                providerKinds = providerKinds,\n                computedAtUtc = now,\n            ),\n        )\n    }\n\n    private suspend fun loadHistory(performanceId: PerformanceId): EventHistoryResponse {\n        return runtimeObservability.traceSpan(\n            name = \"event_intelligence.load_history\",\n            stringAttributes = mapOf(\"tixmeup.performance_id\" to performanceId.value),\n        ) {\n            val marketHistory = loadObservationHistory(performanceId)\n            EventHistoryResponse(samples = marketHistory.map(::toHistorySample))\n        }\n    }\n\n    private suspend fun loadObservationHistory(performanceId: PerformanceId): List<ObservationHistoryEntry> {\n        return dependencies.observationHistoryService.historyForPerformance(performanceId)\n    }\n\n    private suspend fun loadTimeline(\n        performanceId: PerformanceId,\n        intelligence: EventIntelligenceView,\n        now: Instant,\n    ): EventTimelineResponse =\n        runtimeObservability.traceSpan(\n            name = \"event_intelligence.load_timeline\",\n            stringAttributes = mapOf(\"tixmeup.performance_id\" to performanceId.value),\n        ) {\n            coroutineScope {\n                val signalSnapshotsDeferred = async { dependencies.signalSnapshotRepository.findByPerformance(performanceId) }\n                val marketEventsDeferred = async { dependencies.marketEventRepository.findByPerformance(performanceId) }\n                val signalSnapshots = signalSnapshotsDeferred.await()\n                val marketEvents = marketEventsDeferred.await()\n                EventTimelineResponse(\n                    signalSnapshots =\n                        signalSnapshots\n                            .map(::toSignalSnapshot)\n                            .ifEmpty { intelligence.toSignalSnapshots(now) }\n                            .sortedWith(compareByDescending<EventSignalSnapshotResponse> { it.observedAtUtc }.thenBy { it.signalId }),\n","exit_code":0,"status":"completed"}}
