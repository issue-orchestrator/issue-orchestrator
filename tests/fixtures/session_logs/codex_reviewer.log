{"type":"item.completed","item":{"id":"item_17","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,460p' inventory-impl/src/main/kotlin/com/tixmeup/inventory/impl/JdbcObservationHistoryService.kt\"","aggregated_output":"@file:Suppress(\"MagicNumber\", \"NestedBlockDepth\", \"TooGenericExceptionCaught\")\n\npackage com.tixmeup.inventory.impl\n\nimport com.fasterxml.jackson.module.kotlin.jacksonObjectMapper\nimport com.fasterxml.jackson.module.kotlin.readValue\nimport com.tixmeup.domain.CurrencyCode\nimport com.tixmeup.domain.GeographyHint\nimport com.tixmeup.domain.Money\nimport com.tixmeup.domain.ObservationBatchId\nimport com.tixmeup.domain.OfferSnapshotId\nimport com.tixmeup.domain.PerformanceId\nimport com.tixmeup.domain.SourceEventId\nimport com.tixmeup.domain.SourceName\nimport com.tixmeup.domain.TimeZoneId\nimport com.tixmeup.domain.moneyOf\nimport com.tixmeup.inventory.api.ObservationHistoryEntry\nimport com.tixmeup.inventory.api.ObservationHistoryService\nimport com.tixmeup.ports.ObservationBatchRecord\nimport com.tixmeup.ports.ObservationBatchRepository\nimport com.tixmeup.ports.OfferSnapshotRecord\nimport com.tixmeup.ports.OfferSnapshotRepository\nimport com.tixmeup.ports.PersistableObservationBatch\nimport com.tixmeup.ports.SourceEventRecord\nimport com.tixmeup.ports.SourceEventRepository\nimport java.sql.PreparedStatement\nimport java.sql.ResultSet\nimport java.time.LocalDate\nimport java.time.LocalTime\nimport java.time.OffsetDateTime\nimport javax.sql.DataSource\n\nprivate val observationObjectMapper = jacksonObjectMapper().findAndRegisterModules()\n\n@Suppress(\"TooManyFunctions\")\ninternal class JdbcObservationHistoryService(\n    private val dataSource: DataSource,\n) : ObservationHistoryService, ObservationBatchRepository, SourceEventRepository, OfferSnapshotRepository {\n    override suspend fun record(batch: PersistableObservationBatch) {\n        dataSource.connection.use { connection ->\n            connection.withTransaction {\n                connection.prepareStatement(BATCH_UPSERT).use { batchStatement ->\n                    saveBatch(batchStatement, batch.batch)\n                }\n                connection.prepareStatement(SOURCE_EVENT_UPSERT).use { sourceEventStatement ->\n                    batch.sourceEvents.forEach { saveSourceEvent(sourceEventStatement, it) }\n                }\n                connection.prepareStatement(BATCH_SOURCE_EVENT_UPSERT).use { linkStatement ->\n                    batch.batch.sourceEventIds.forEach { sourceEventId ->\n                        saveBatchSourceEventLink(linkStatement, batch.batch.batchId, sourceEventId)\n                    }\n                }\n                connection.prepareStatement(SNAPSHOT_UPSERT).use { snapshotStatement ->\n                    batch.offerSnapshots.forEach { saveSnapshot(snapshotStatement, it) }\n                }\n            }\n        }\n    }\n\n    override suspend fun historyForSourceEvent(sourceEventId: SourceEventId): List<ObservationHistoryEntry> =\n        dataSource.connection.use { connection ->\n            connection.prepareStatement(HISTORY_BY_SOURCE_EVENT).use { statement ->\n                statement.setString(1, sourceEventId.value)\n                statement.executeQuery().use(::readObservationHistoryEntries)\n            }\n        }\n\n    override suspend fun historyForPerformance(performanceId: PerformanceId): List<ObservationHistoryEntry> =\n        dataSource.connection.use { connection ->\n            connection.prepareStatement(HISTORY_BY_PERFORMANCE).use { statement ->\n                statement.setString(1, performanceId.value)\n                statement.setString(2, performanceId.value)\n                statement.setString(3, performanceId.value)\n                statement.executeQuery().use(::readObservationHistoryEntries)\n            }\n        }\n\n    override suspend fun latestForProvider(provider: SourceName): List<ObservationHistoryEntry> =\n        dataSource.connection.use { connection ->\n            connection.prepareStatement(LATEST_BY_PROVIDER).use { statement ->\n                statement.setString(1, provider.value)\n                statement.executeQuery().use(::readObservationHistoryEntries)\n            }\n        }\n\n    override suspend fun save(batch: ObservationBatchRecord) {\n        dataSource.connection.use { connection ->\n            connection.prepareStatement(BATCH_UPSERT).use { saveBatch(it, batch) }\n        }\n    }\n\n    override suspend fun find(batchId: ObservationBatchId): ObservationBatchRecord? =\n        dataSource.connection.use { connection ->\n            connection.prepareStatement(BATCH_FIND).use { statement ->\n                statement.setString(1, batchId.value)\n                statement.executeQuery().use { resultSet ->\n                    if (!resultSet.next()) {\n                        return@use null\n                    }\n                    ObservationBatchRecord(\n                        batchId = ObservationBatchId(resultSet.getString(\"batch_id\")),\n                        provider = SourceName(resultSet.getString(\"provider\")),\n                        observedAtUtc = resultSet.getObject(\"observed_at_utc\", OffsetDateTime::class.java).toInstant(),\n                        sourceEventIds = loadBatchSourceEventIds(connection, batchId),\n                    )\n                }\n            }\n        }\n\n    override suspend fun save(record: SourceEventRecord) {\n        dataSource.connection.use { connection ->\n            connection.prepareStatement(SOURCE_EVENT_UPSERT).use { saveSourceEvent(it, record) }\n        }\n    }\n\n    override suspend fun find(sourceEventId: SourceEventId): SourceEventRecord? =\n        dataSource.connection.use { connection ->\n            connection.prepareStatement(SOURCE_EVENT_FIND).use { statement ->\n                statement.setString(1, sourceEventId.value)\n                statement.executeQuery().use { resultSet ->\n                    if (!resultSet.next()) {\n                        return@use null\n                    }\n                    SourceEventRecord(\n                        sourceEventId = SourceEventId(resultSet.getString(\"source_event_id\")),\n                        provider = SourceName(resultSet.getString(\"provider\")),\n                        title = resultSet.getString(\"title\"),\n                        venueName = resultSet.getString(\"venue_name\"),\n                        localDate = resultSet.getObject(\"local_date\", LocalDate::class.java),\n                        localTime = resultSet.getObject(\"local_time\", LocalTime::class.java),\n                        timezone = resultSet.getString(\"timezone\")?.let(::TimeZoneId),\n                        geographyHint = resultSet.getString(\"geography_hint\")?.let(::GeographyHint),\n                        observedAtUtc = resultSet.getObject(\"observed_at_utc\", OffsetDateTime::class.java).toInstant(),\n                    )\n                }\n            }\n        }\n\n    override suspend fun save(snapshot: OfferSnapshotRecord) {\n        dataSource.connection.use { connection ->\n            connection.prepareStatement(SNAPSHOT_UPSERT).use { saveSnapshot(it, snapshot) }\n        }\n    }\n\n    override suspend fun findByPerformance(performanceId: PerformanceId): List<OfferSnapshotRecord> =\n        dataSource.connection.use { connection ->\n            connection.prepareStatement(SNAPSHOTS_BY_PERFORMANCE).use { statement ->\n                statement.setString(1, performanceId.value)\n                statement.executeQuery().use { resultSet ->\n                    buildList {\n                        while (resultSet.next()) {\n                            add(\n                                OfferSnapshotRecord(\n                                    snapshotId = OfferSnapshotId(resultSet.getString(\"snapshot_id\")),\n                                    sourceEventId = SourceEventId(resultSet.getString(\"source_event_id\")),\n                                    performanceId = resultSet.getString(\"performance_id\")?.let(::PerformanceId),\n                                    provider = SourceName(resultSet.getString(\"provider\")),\n                                    observedAtUtc = resultSet.getObject(\"observed_at_utc\", OffsetDateTime::class.java).toInstant(),\n                                    visibleMinPrice = moneyFrom(resultSet, \"visible_min_amount\", \"visible_min_currency\"),\n                                    allInMinPrice = moneyFrom(resultSet, \"all_in_min_amount\", \"all_in_min_currency\"),\n                                    availableTicketCount = nullableInt(resultSet, \"available_ticket_count\"),\n                                    state = enumValueOf(resultSet.getString(\"state\")),\n                                    supportNotes = observationObjectMapper.readValue(resultSet.getString(\"support_notes_json\")),\n                                ),\n                            )\n                        }\n                    }\n                }\n            }\n        }\n\n    private fun loadBatchSourceEventIds(\n        connection: java.sql.Connection,\n        batchId: ObservationBatchId,\n    ): List<SourceEventId> =\n        connection.prepareStatement(BATCH_SOURCE_EVENT_IDS).use { statement ->\n            statement.setString(1, batchId.value)\n            statement.executeQuery().use { resultSet ->\n                buildList {\n                    while (resultSet.next()) {\n                        add(SourceEventId(resultSet.getString(\"source_event_id\")))\n                    }\n                }\n            }\n        }\n\n    private fun saveBatch(\n        statement: PreparedStatement,\n        batch: ObservationBatchRecord,\n    ) {\n        statement.clearParameters()\n        statement.bindBatch(batch)\n        statement.executeUpdate()\n    }\n\n    private fun saveSourceEvent(\n        statement: PreparedStatement,\n        record: SourceEventRecord,\n    ) {\n        statement.clearParameters()\n        statement.bindSourceEvent(record)\n        statement.executeUpdate()\n    }\n\n    private fun saveSnapshot(\n        statement: PreparedStatement,\n        snapshot: OfferSnapshotRecord,\n    ) {\n        statement.clearParameters()\n        statement.bindSnapshot(snapshot)\n        statement.executeUpdate()\n    }\n\n    private fun saveBatchSourceEventLink(\n        statement: PreparedStatement,\n        batchId: ObservationBatchId,\n        sourceEventId: SourceEventId,\n    ) {\n        statement.clearParameters()\n        statement.bindBatchSourceEventLink(batchId, sourceEventId)\n        statement.executeUpdate()\n    }\n}\n\nprivate fun readObservationHistoryEntries(resultSet: ResultSet): List<ObservationHistoryEntry> =\n    buildList {\n        while (resultSet.next()) {\n            add(\n                ObservationHistoryEntry(\n                    sourceEventId = SourceEventId(resultSet.getString(\"source_event_id\")),\n                    provider = SourceName(resultSet.getString(\"provider\")),\n                    title = resultSet.getString(\"title\"),\n                    venueName = resultSet.getString(\"venue_name\"),\n                    observedAtUtc = resultSet.getObject(\"observed_at_utc\", OffsetDateTime::class.java).toInstant(),\n                    visibleMinPrice = moneyFrom(resultSet, \"visible_min_amount\", \"visible_min_currency\"),\n                    allInMinPrice = moneyFrom(resultSet, \"all_in_min_amount\", \"all_in_min_currency\"),\n                    availableTicketCount = nullableInt(resultSet, \"available_ticket_count\"),\n                    state = enumValueOf(resultSet.getString(\"state\")),\n                    supportNotes = observationObjectMapper.readValue(resultSet.getString(\"support_notes_json\")),\n                ),\n            )\n        }\n    }\n\nprivate fun moneyFrom(\n    resultSet: java.sql.ResultSet,\n    amountColumn: String,\n    currencyColumn: String,\n): Money? {\n    val amount = resultSet.getBigDecimal(amountColumn) ?: return null\n    val currency = resultSet.getString(currencyColumn) ?: return null\n    return moneyOf(amount, CurrencyCode(currency))\n}\n\nprivate fun nullableInt(\n    resultSet: java.sql.ResultSet,\n    column: String,\n): Int? {\n    val value = resultSet.getInt(column)\n    return if (resultSet.wasNull()) {\n        null\n    } else {\n        value\n    }\n}\n\nprivate fun setMoney(\n    statement: PreparedStatement,\n    amountIndex: Int,\n    currencyIndex: Int,\n    money: Money?,\n) {\n    if (money == null) {\n        statement.setObject(amountIndex, null)\n        statement.setString(currencyIndex, null)\n    } else {\n        statement.setBigDecimal(amountIndex, money.amount)\n        statement.setString(currencyIndex, money.currencyCode.value)\n    }\n}\n\nprivate fun PreparedStatement.bindBatch(batch: ObservationBatchRecord) {\n    setString(1, batch.batchId.value)\n    setString(2, batch.provider.value)\n    setObject(3, OffsetDateTime.ofInstant(batch.observedAtUtc, java.time.ZoneOffset.UTC))\n}\n\nprivate fun PreparedStatement.bindSourceEvent(record: SourceEventRecord) {\n    setString(1, record.sourceEventId.value)\n    setString(2, record.provider.value)\n    setString(3, record.title)\n    setString(4, record.venueName)\n    setObject(5, record.localDate)\n    setObject(6, record.localTime)\n    setString(7, record.timezone?.value)\n    setString(8, record.geographyHint?.value)\n    setObject(9, OffsetDateTime.ofInstant(record.observedAtUtc, java.time.ZoneOffset.UTC))\n}\n\nprivate fun PreparedStatement.bindSnapshot(snapshot: OfferSnapshotRecord) {\n    setString(1, snapshot.snapshotId.value)\n    setString(2, snapshot.sourceEventId.value)\n    setString(3, snapshot.performanceId?.value)\n    setString(4, snapshot.provider.value)\n    setObject(5, OffsetDateTime.ofInstant(snapshot.observedAtUtc, java.time.ZoneOffset.UTC))\n    setMoney(this, 6, 7, snapshot.visibleMinPrice)\n    setMoney(this, 8, 9, snapshot.allInMinPrice)\n    setObject(10, snapshot.availableTicketCount)\n    setString(11, snapshot.state.name)\n    setString(12, observationObjectMapper.writeValueAsString(snapshot.supportNotes))\n}\n\nprivate fun PreparedStatement.bindBatchSourceEventLink(\n    batchId: ObservationBatchId,\n    sourceEventId: SourceEventId,\n) {\n    setString(1, batchId.value)\n    setString(2, sourceEventId.value)\n}\n\nprivate inline fun <T> java.sql.Connection.withTransaction(block: () -> T): T {\n    val originalAutoCommit = autoCommit\n    autoCommit = false\n    try {\n        val result = block()\n        commit()\n        return result\n    } catch (exception: Exception) {\n        rollback()\n        throw exception\n    } finally {\n        autoCommit = originalAutoCommit\n    }\n}\n\nprivate const val BATCH_UPSERT =\n    \"\"\"\n    insert into observation_batches (batch_id, provider, observed_at_utc)\n    values (?, ?, ?)\n    on conflict (batch_id) do update\n    set provider = excluded.provider,\n        observed_at_utc = excluded.observed_at_utc\n    \"\"\"\n\nprivate const val SOURCE_EVENT_UPSERT =\n    \"\"\"\n    insert into source_events (\n        source_event_id, provider, title, venue_name, local_date, local_time, timezone, geography_hint, observed_at_utc\n    ) values (?, ?, ?, ?, ?, ?, ?, ?, ?)\n    on conflict (source_event_id) do update\n    set provider = excluded.provider,\n        title = excluded.title,\n        venue_name = excluded.venue_name,\n        local_date = excluded.local_date,\n        local_time = excluded.local_time,\n        timezone = excluded.timezone,\n        geography_hint = excluded.geography_hint,\n        observed_at_utc = excluded.observed_at_utc\n    \"\"\"\n\nprivate const val BATCH_SOURCE_EVENT_UPSERT =\n    \"\"\"\n    insert into batch_source_events (batch_id, source_event_id)\n    values (?, ?)\n    on conflict (batch_id, source_event_id) do nothing\n    \"\"\"\n\nprivate const val SNAPSHOT_UPSERT =\n    \"\"\"\n    insert into offer_snapshots (\n        snapshot_id, source_event_id, performance_id, provider, observed_at_utc,\n        visible_min_amount, visible_min_currency, all_in_min_amount, all_in_min_currency,\n        available_ticket_count, state, support_notes_json\n    ) values (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, cast(? as jsonb))\n    on conflict (snapshot_id) do update\n    set source_event_id = excluded.source_event_id,\n        performance_id = excluded.performance_id,\n        provider = excluded.provider,\n        observed_at_utc = excluded.observed_at_utc,\n        visible_min_amount = excluded.visible_min_amount,\n        visible_min_currency = excluded.visible_min_currency,\n        all_in_min_amount = excluded.all_in_min_amount,\n        all_in_min_currency = excluded.all_in_min_currency,\n        available_ticket_count = excluded.available_ticket_count,\n        state = excluded.state,\n        support_notes_json = excluded.support_notes_json\n    \"\"\"\n\nprivate const val HISTORY_BY_SOURCE_EVENT =\n    \"\"\"\n    select se.source_event_id, os.provider, se.title, se.venue_name, os.observed_at_utc,\n           os.visible_min_amount, os.visible_min_currency, os.all_in_min_amount, os.all_in_min_currency, os.available_ticket_count,\n           os.state, os.support_notes_json\n      from offer_snapshots os\n      join source_events se on se.source_event_id = os.source_event_id\n     where os.source_event_id = ?\n     order by os.observed_at_utc asc\n    \"\"\"\n\n// union all is safe: the `os.performance_id is distinct from ?` guard makes the two\n// branches mutually exclusive, so no snapshot can appear in both, and source_event_mappings\n// keys on source_event_id so branch 2 emits each snapshot at most once.\nprivate const val HISTORY_BY_PERFORMANCE =\n    \"\"\"\n    select se.source_event_id, os.provider, se.title, se.venue_name, os.observed_at_utc,\n           os.visible_min_amount, os.visible_min_currency, os.all_in_min_amount, os.all_in_min_currency, os.available_ticket_count,\n           os.state, os.support_notes_json\n      from offer_snapshots os\n      join source_events se on se.source_event_id = os.source_event_id\n     where os.performance_id = ?\n    union all\n    select se.source_event_id, os.provider, se.title, se.venue_name, os.observed_at_utc,\n           os.visible_min_amount, os.visible_min_currency, os.all_in_min_amount, os.all_in_min_currency, os.available_ticket_count,\n           os.state, os.support_notes_json\n      from source_event_mappings sem\n      join offer_snapshots os on os.source_event_id = sem.source_event_id\n      join source_events se on se.source_event_id = os.source_event_id\n     where sem.performance_id = ?\n       and os.performance_id is distinct from ?\n     order by observed_at_utc asc, provider asc, source_event_id asc\n    \"\"\"\n\nprivate const val LATEST_BY_PROVIDER =\n    \"\"\"\n    select source_event_id, provider, title, venue_name, observed_at_utc,\n           visible_min_amount, visible_min_currency, all_in_min_amount, all_in_min_currency,\n           available_ticket_count, state, support_notes_json\n      from (\n            select se.source_event_id,\n                   os.provider,\n                   se.title,\n                   se.venue_name,\n                   os.observed_at_utc,\n                   os.visible_min_amount,\n                   os.visible_min_currency,\n                   os.all_in_min_amount,\n                   os.all_in_min_currency,\n                   os.available_ticket_count,\n                   os.state,\n                   os.support_notes_json,\n                   row_number() over (partition by os.source_event_id order by os.observed_at_utc desc) as row_rank\n              from offer_snapshots os\n              join source_events se on se.source_event_id = os.source_event_id\n             where os.provider = ?\n           ) ranked\n     where row_rank = 1\n     order by source_event_id\n    \"\"\"\n\nprivate const val BATCH_FIND =\n    \"\"\"\n    select batch_id, provider, observed_at_utc\n      from observation_batches\n     where batch_id = ?\n    \"\"\"\n\nprivate const val BATCH_SOURCE_EVENT_IDS =\n    \"\"\"\n    select source_event_id\n      from batch_source_events\n","exit_code":0,"status":"completed"}}
