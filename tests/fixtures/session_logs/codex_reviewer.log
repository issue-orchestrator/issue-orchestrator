{"type":"item.completed","item":{"id":"item_23","type":"command_execution","command":"/bin/zsh -lc \"sed -n '100,180p' integration-tests/src/test/kotlin/com/tixmeup/integration/RuntimeScaleExecutionSupport.kt\"","aggregated_output":"            }.awaitAll().flatten()\n        }\n\n    suspend fun runBurst(\n        baseUrls: List<String>,\n        path: String,\n        requestCount: Int,\n    ): List<RuntimeScaleRequestResult> =\n        coroutineScope {\n            val client = HttpClient.newHttpClient()\n            (0 until requestCount).map { index ->\n                async(Dispatchers.IO) {\n                    request(client, baseUrls[index % baseUrls.size], path)\n                }\n            }.awaitAll()\n        }\n\n    fun explainSourceEventMappings(\n        connectionInfo: PostgresConnectionInfo,\n        performanceId: PerformanceId,\n    ): String =\n        explain(\n            connectionInfo,\n            \"\"\"\n            select *\n              from source_event_mappings\n             where performance_id = ?\n            \"\"\".trimIndent(),\n            listOf(performanceId.value),\n        )\n\n    fun explainHistoryByPerformance(\n        connectionInfo: PostgresConnectionInfo,\n        performanceId: PerformanceId,\n    ): String =\n        explain(\n            connectionInfo,\n            \"\"\"\n            select se.source_event_id, os.provider, se.title, se.venue_name, os.observed_at_utc,\n                   os.visible_min_amount, os.visible_min_currency, os.all_in_min_amount, os.all_in_min_currency, os.available_ticket_count,\n                   os.state, os.support_notes_json\n              from offer_snapshots os\n              join source_events se on se.source_event_id = os.source_event_id\n             where os.performance_id = ?\n            union\n            select se.source_event_id, os.provider, se.title, se.venue_name, os.observed_at_utc,\n                   os.visible_min_amount, os.visible_min_currency, os.all_in_min_amount, os.all_in_min_currency, os.available_ticket_count,\n                   os.state, os.support_notes_json\n              from source_event_mappings sem\n              join offer_snapshots os on os.source_event_id = sem.source_event_id\n              join source_events se on se.source_event_id = os.source_event_id\n             where sem.performance_id = ?\n               and os.performance_id is distinct from ?\n             order by observed_at_utc asc, provider asc, source_event_id asc\n            \"\"\".trimIndent(),\n            listOf(performanceId.value, performanceId.value, performanceId.value),\n        )\n\n    fun startServer(runtime: AutoCloseableDemoRuntime): StartedHttpRuntime {\n        val port = freePort()\n        val server =\n            ApiServerHttp.netty(\n                graph = runtime.graph,\n                config = ApiServerHttpConfig(host = \"0.0.0.0\", port = port),\n            )\n        server.start(wait = false)\n        return StartedHttpRuntime(runtime, \"http://127.0.0.1:$port\", server)\n    }\n\n    private fun explain(\n        connectionInfo: PostgresConnectionInfo,\n        sql: String,\n        params: List<String>,\n    ): String {\n        return PostgresTestSupport.dataSource(connectionInfo).connection.use { connection ->\n            connection.prepareStatement(\"EXPLAIN (ANALYZE, BUFFERS, VERBOSE) $sql\").use { statement ->\n                params.forEachIndexed { index, value -> statement.setString(index + 1, value) }\n                statement.executeQuery().use { resultSet ->\n                    buildString {\n                        while (resultSet.next()) {\n                            appendLine(resultSet.getString(1))\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_24","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,150p' inventory-impl/src/main/kotlin/com/tixmeup/inventory/impl/JdbcSourceEventMappingRepository.kt\"","aggregated_output":"@file:Suppress(\"MagicNumber\", \"NestedBlockDepth\")\n\npackage com.tixmeup.inventory.impl\n\nimport com.tixmeup.domain.ConfidenceScore\nimport com.tixmeup.domain.PerformanceId\nimport com.tixmeup.domain.SourceEventId\nimport com.tixmeup.ports.SourceEventMappingRecord\nimport com.tixmeup.ports.SourceEventMappingRepository\nimport java.math.BigDecimal\nimport java.time.OffsetDateTime\nimport javax.sql.DataSource\n\ninternal class JdbcSourceEventMappingRepository(\n    private val dataSource: DataSource,\n) : SourceEventMappingRepository {\n    override suspend fun save(mapping: SourceEventMappingRecord) {\n        dataSource.connection.use { connection ->\n            connection.prepareStatement(MAPPING_UPSERT).use { statement ->\n                statement.setString(1, mapping.sourceEventId.value)\n                statement.setString(2, mapping.performanceId.value)\n                statement.setBigDecimal(3, BigDecimal.valueOf(mapping.confidence.value))\n                statement.setString(4, mapping.disposition.name)\n                statement.setObject(5, OffsetDateTime.ofInstant(mapping.matchedAtUtc, java.time.ZoneOffset.UTC))\n                statement.setString(6, mapping.reason)\n                statement.executeUpdate()\n            }\n        }\n    }\n\n    override suspend fun find(sourceEventId: SourceEventId): SourceEventMappingRecord? =\n        dataSource.connection.use { connection ->\n            connection.prepareStatement(MAPPING_FIND).use { statement ->\n                statement.setString(1, sourceEventId.value)\n                statement.executeQuery().use { resultSet ->\n                    if (!resultSet.next()) {\n                        return@use null\n                    }\n                    SourceEventMappingRecord(\n                        sourceEventId = SourceEventId(resultSet.getString(\"source_event_id\")),\n                        performanceId = PerformanceId(resultSet.getString(\"performance_id\")),\n                        confidence = ConfidenceScore(resultSet.getBigDecimal(\"confidence\").toDouble()),\n                        disposition = enumValueOf(resultSet.getString(\"disposition\")),\n                        matchedAtUtc = resultSet.getObject(\"matched_at_utc\", OffsetDateTime::class.java).toInstant(),\n                        reason = resultSet.getString(\"reason\"),\n                    )\n                }\n            }\n        }\n\n    override suspend fun findByPerformance(performanceId: PerformanceId): List<SourceEventMappingRecord> =\n        dataSource.connection.use { connection ->\n            connection.prepareStatement(MAPPINGS_BY_PERFORMANCE).use { statement ->\n                statement.setString(1, performanceId.value)\n                statement.executeQuery().use { resultSet ->\n                    buildList {\n                        while (resultSet.next()) {\n                            add(\n                                SourceEventMappingRecord(\n                                    sourceEventId = SourceEventId(resultSet.getString(\"source_event_id\")),\n                                    performanceId = PerformanceId(resultSet.getString(\"performance_id\")),\n                                    confidence = ConfidenceScore(resultSet.getBigDecimal(\"confidence\").toDouble()),\n                                    disposition = enumValueOf(resultSet.getString(\"disposition\")),\n                                    matchedAtUtc = resultSet.getObject(\"matched_at_utc\", OffsetDateTime::class.java).toInstant(),\n                                    reason = resultSet.getString(\"reason\"),\n                                ),\n                            )\n                        }\n                    }\n                }\n            }\n        }\n}\n\nprivate const val MAPPING_UPSERT =\n    \"\"\"\n    insert into source_event_mappings (\n        source_event_id, performance_id, confidence, disposition, matched_at_utc, reason\n    ) values (?, ?, ?, ?, ?, ?)\n    on conflict (source_event_id) do update\n    set performance_id = excluded.performance_id,\n        confidence = excluded.confidence,\n        disposition = excluded.disposition,\n        matched_at_utc = excluded.matched_at_utc,\n        reason = excluded.reason\n    \"\"\"\n\nprivate const val MAPPING_FIND =\n    \"\"\"\n    select source_event_id, performance_id, confidence, disposition, matched_at_utc, reason\n      from source_event_mappings\n     where source_event_id = ?\n    \"\"\"\n\nprivate const val MAPPINGS_BY_PERFORMANCE =\n    \"\"\"\n    select source_event_id, performance_id, confidence, disposition, matched_at_utc, reason\n      from source_event_mappings\n     where performance_id = ?\n     order by matched_at_utc asc, source_event_id asc\n    \"\"\"\n","exit_code":0,"status":"completed"}}
