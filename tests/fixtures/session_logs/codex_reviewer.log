d: SourceEventId): List<ObservationHistoryEntry> =\n        synchronized(lock) {\n            val sourceEvent = sourceEvents[sourceEventId] ?: return@synchronized emptyList()\n            snapshots.values\n                .filter { it.sourceEventId == sourceEventId }\n                .sortedBy { it.observedAtUtc }\n                .map { snapshot ->\n                    ObservationHistoryEntry(\n                        sourceEventId = sourceEventId,\n                        provider = snapshot.provider,\n                        title = sourceEvent.title,\n                        venueName = sourceEvent.venueName,\n                        observedAtUtc = snapshot.observedAtUtc,\n                        visibleMinPrice = snapshot.visibleMinPrice,\n                        allInMinPrice = snapshot.allInMinPrice,\n                        availableTicketCount = snapshot.availableTicketCount,\n                        state = snapshot.state,\n                        supportNotes = snapshot.supportNotes,\n                    )\n                }\n        }\n\n    override suspend fun historyForPerformance(performanceId: PerformanceId): List<ObservationHistoryEntry> =\n        synchronized(lock) {\n            snapshots.values\n                .filter { snapshot ->\n                    snapshot.performanceId == performanceId ||\n                        mappedPerformanceIds[snapshot.sourceEventId] == performanceId\n                }.distinctBy { it.snapshotId }\n                .sortedWith(compareBy({ it.observedAtUtc }, { it.provider.value }, { it.sourceEventId.value }))\n                .mapNotNull { snapshot ->\n                    val sourceEvent = sourceEvents[snapshot.sourceEventId] ?: return@mapNotNull null\n                    ObservationHistoryEntry(\n                        sourceEventId = snapshot.sourceEventId,\n                        provider = snapshot.provider,\n                        title = sourceEvent.title,\n                        venueName = sourceEvent.