{"type":"item.completed","item":{"id":"item_40","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,170p' api-server/src/main/kotlin/com/tixmeup/api/EventHistoryQueryService.kt\"","aggregated_output":"package com.tixmeup.api\n\nimport com.tixmeup.domain.CachePolicies\nimport com.tixmeup.domain.EventHistoryCacheKey\nimport com.tixmeup.domain.PerformanceId\nimport com.tixmeup.domain.PerformanceSlug\nimport com.tixmeup.inventory.api.ObservationHistoryEntry\nimport com.tixmeup.inventory.api.ObservationHistoryService\nimport com.tixmeup.ports.LayeredReadCache\nimport com.tixmeup.ports.LayeredReadCacheConfig\nimport com.tixmeup.ports.NoOpRuntimeObservability\nimport com.tixmeup.ports.PerformanceRepository\nimport com.tixmeup.ports.RuntimeObservability\nimport com.tixmeup.ports.SourceEventMappingRepository\nimport java.time.Instant\n\nclass EventHistoryQueryService(\n    private val dependencies: EventHistoryDependencies,\n    cacheConfig: EventReadCacheConfig = EventReadCacheConfig(policy = CachePolicies.eventHistory),\n    private val runtimeObservability: RuntimeObservability = NoOpRuntimeObservability,\n    private val nowProvider: () -> Instant = Instant::now,\n) {\n    private val cache =\n        LayeredReadCache(\n            config =\n                LayeredReadCacheConfig(\n                    policy = cacheConfig.policy,\n                    distributedCache = cacheConfig.readModelCache,\n                    cacheMetricStore = cacheConfig.cacheMetricStore,\n                    nowProvider = nowProvider,\n                    coroutineScope = cacheConfig.coroutineScope,\n                ),\n            encode = { apiServerCacheObjectMapper.writeValueAsString(it.toCachedRecord()) },\n            decode = { payload -> apiServerCacheObjectMapper.decodeCacheValue<CachedEventHistoryLookupRecord>(payload).toLookupResult() },\n        )\n\n    suspend fun load(\n        slug: PerformanceSlug,\n        window: EventHistoryWindow,\n    ): EventHistoryLookupResult {\n        val resolution = dependencies.slugResolver.resolve(slug) ?: return EventHistoryNotFound\n        return cache.getOrLoad(EventHistoryCacheKey(resolution.canonicalSlug, window.name.lowercase())) {\n            uncachedLoad(resolution, window)\n        }\n    }\n\n    private suspend fun uncachedLoad(\n        resolution: EventSlugResolution,\n        window: EventHistoryWindow,\n    ): EventHistoryLookupResult {\n        return runtimeObservability.traceSpan(\n            name = \"event_history.load\",\n            stringAttributes =\n                mapOf(\n                    \"tixmeup.slug\" to resolution.canonicalSlug.value,\n                    \"tixmeup.performance_id\" to resolution.performanceId.value,\n                    \"tixmeup.window\" to window.name,\n                ),\n        ) {\n            val performance = dependencies.performanceRepository.find(resolution.performanceId) ?: return@traceSpan EventHistoryNotFound\n            val samples = loadWindowSamples(resolution.performanceId, window)\n\n            EventHistoryFound(\n                EventHistoryQueryResponse(\n                    slug = resolution.canonicalSlug,\n                    title = performance.title,\n                    selectedWindow = window,\n                    supportedWindows = EventHistoryWindow.entries,\n                    density = densityFor(samples.size),\n                    sourceProviders = samples.map { it.provider.value }.distinct().sorted(),\n                    priceSamples = samples.map(::toPricePoint),\n                    inventorySamples = samples.map(::toInventoryPoint),\n                ),\n            )\n        }\n    }\n\n    private suspend fun loadWindowSamples(\n        performanceId: PerformanceId,\n        window: EventHistoryWindow,\n    ): List<ObservationHistoryEntry> {\n        return runtimeObservability.traceSpan(\n            name = \"event_history.load_window_samples\",\n            stringAttributes =\n                mapOf(\n                    \"tixmeup.performance_id\" to performanceId.value,\n                    \"tixmeup.window\" to window.name,\n                ),\n        ) {\n            val cutoff = nowProvider().minus(window.duration)\n            loadObservationHistory(performanceId)\n                .filter { it.observedAtUtc >= cutoff }\n        }\n    }\n\n    private suspend fun loadObservationHistory(performanceId: PerformanceId): List<ObservationHistoryEntry> {\n        return dependencies.observationHistoryService.historyForPerformance(performanceId)\n    }\n}\n\ndata class EventHistoryDependencies(\n    val slugResolver: EventSlugResolver,\n    val performanceRepository: PerformanceRepository,\n    val observationHistoryService: ObservationHistoryService,\n    val sourceEventMappingRepository: SourceEventMappingRepository,\n)\n\nprivate const val SPARSE_HISTORY_THRESHOLD = 4\n\nprivate fun densityFor(sampleCount: Int): EventHistoryDensity =\n    when {\n        sampleCount == 0 -> EventHistoryDensity.EMPTY\n        sampleCount < SPARSE_HISTORY_THRESHOLD -> EventHistoryDensity.SPARSE\n        else -> EventHistoryDensity.DENSE\n    }\n\nprivate fun toPricePoint(sample: ObservationHistoryEntry) =\n    EventPriceHistoryPointResponse(\n        provider = sample.provider.value,\n        observedAtUtc = sample.observedAtUtc,\n        visibleMinPrice = sample.visibleMinPrice?.amount,\n        allInMinPrice = sample.allInMinPrice?.amount,\n    )\n\nprivate fun toInventoryPoint(sample: ObservationHistoryEntry) =\n    EventInventoryHistoryPointResponse(\n        provider = sample.provider.value,\n        observedAtUtc = sample.observedAtUtc,\n        availableTicketCount = sample.availableTicketCount,\n        state = sample.state,\n    )\n\nprivate data class CachedEventHistoryLookupRecord(\n    val found: Boolean,\n    val response: EventHistoryQueryResponse? = null,\n) {\n    fun toLookupResult(): EventHistoryLookupResult = if (found) EventHistoryFound(requireNotNull(response)) else EventHistoryNotFound\n}\n\nprivate fun EventHistoryLookupResult.toCachedRecord(): CachedEventHistoryLookupRecord =\n    when (this) {\n        is EventHistoryFound -> CachedEventHistoryLookupRecord(found = true, response = response)\n        EventHistoryNotFound -> CachedEventHistoryLookupRecord(found = false)\n    }\n","exit_code":0,"status":"completed"}}
