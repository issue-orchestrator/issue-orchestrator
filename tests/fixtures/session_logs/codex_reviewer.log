{"type":"item.completed","item":{"id":"item_19","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,280p' inventory-impl/src/test/kotlin/com/tixmeup/inventory/impl/JdbcObservationHistoryServiceTest.kt\"","aggregated_output":"package com.tixmeup.inventory.impl\n\nimport com.tixmeup.domain.ConfidenceScore\nimport com.tixmeup.domain.CurrencyCode\nimport com.tixmeup.domain.GeographyHint\nimport com.tixmeup.domain.MatchDisposition\nimport com.tixmeup.domain.ObservationBatchId\nimport com.tixmeup.domain.OfferSnapshotId\nimport com.tixmeup.domain.PerformanceId\nimport com.tixmeup.domain.SnapshotState\nimport com.tixmeup.domain.SourceEventId\nimport com.tixmeup.domain.SourceName\nimport com.tixmeup.domain.TimeZoneId\nimport com.tixmeup.domain.moneyOf\nimport com.tixmeup.ingestion.impl.IngestionServices\nimport com.tixmeup.ports.OfferSnapshotRecord\nimport com.tixmeup.ports.SourceEventMappingRecord\nimport com.tixmeup.ports.SourceEventRecord\nimport com.tixmeup.testutils.PostgresTestSupport\nimport com.tixmeup.testutils.fixtures.FileSystemFixtureCatalog\nimport com.tixmeup.testutils.fixtures.FixtureLayout\nimport kotlinx.coroutines.runBlocking\nimport org.junit.jupiter.api.Assertions.assertEquals\nimport org.junit.jupiter.api.Assertions.assertNotNull\nimport org.junit.jupiter.api.Assumptions.assumeTrue\nimport org.junit.jupiter.api.BeforeEach\nimport org.junit.jupiter.api.Test\nimport java.time.Instant\nimport java.time.LocalDate\nimport java.time.LocalTime\n\nclass JdbcObservationHistoryServiceTest {\n    private val dataSource by lazy { PostgresTestSupport.dataSource() }\n    private val root = FixtureLayout.repoRoot()\n    private val replayCatalog = FileSystemFixtureCatalog(root)\n    private val replayNormalizer = IngestionServices.replayNormalizer(replayCatalog, root)\n    private val normalizationService = IngestionServices.normalization()\n    private val historyService by lazy { JdbcObservationHistoryService(dataSource) }\n    private val mappingRepository by lazy { JdbcSourceEventMappingRepository(dataSource) }\n\n    @BeforeEach\n    fun resetDatabase() {\n        assumeTrue(PostgresTestSupport.isAvailable(), PostgresTestSupport.skipReason())\n        PostgresTestSupport.resetSchema(dataSource)\n        PostgresTestSupport.applyMigrations(dataSource)\n    }\n\n    @Test\n    fun `records replay observations into durable history and batch storage`() =\n        runBlocking {\n            val snapshot =\n                replayNormalizer.loadNormalizedSnapshot(\n                    provider = SourceName(\"ticketmaster\"),\n                    scenarioId = \"ticketmaster-calm-example\",\n                )\n            val batch =\n                normalizationService.fromReplaySnapshot(\n                    batchId = ObservationBatchId(\"batch:jdbc:replay\"),\n                    snapshot = snapshot,\n                )\n\n            historyService.record(batch)\n\n            val storedBatch = historyService.find(batch.batch.batchId)\n            val storedSource = historyService.find(snapshot.sourceEventId)\n            val sourceHistory = historyService.historyForSourceEvent(snapshot.sourceEventId)\n            val providerLatest = historyService.latestForProvider(SourceName(\"ticketmaster\"))\n\n            assertNotNull(storedBatch)\n            assertNotNull(storedSource)\n            assertEquals(1, sourceHistory.size)\n            assertEquals(moneyOf(\"120.0\", CurrencyCode(\"USD\")), sourceHistory.single().visibleMinPrice)\n            assertEquals(SnapshotState.AVAILABLE, sourceHistory.single().state)\n            assertEquals(1, providerLatest.size)\n        }\n\n    @Test\n    fun `find by performance returns stored offer history`() =\n        runBlocking {\n            dataSource.connection.use { connection ->\n                connection.createStatement().use { statement ->\n                    statement.execute(\n                        \"\"\"\n                        insert into performances (\n                            performance_id, title, normalized_title, venue_name, normalized_venue_name, local_date, local_time, timezone, geography_hint\n                        ) values (\n                            'perf:1', 'Example Performance', 'example performance', 'Example Venue', 'example venue',\n                            date '2026-03-18', time '19:00:00', 'America/Denver', 'Denver'\n                        )\n                        \"\"\".trimIndent(),\n                    )\n                }\n            }\n            historyService.save(\n                com.tixmeup.ports.SourceEventRecord(\n                    sourceEventId = com.tixmeup.domain.SourceEventId(\"source:perf:1\"),\n                    provider = SourceName(\"stubhub\"),\n                    title = \"Example Performance\",\n                    venueName = \"Example Venue\",\n                    localDate = java.time.LocalDate.parse(\"2026-03-18\"),\n                    localTime = java.time.LocalTime.parse(\"19:00:00\"),\n                    timezone = TimeZoneId(\"America/Denver\"),\n                    geographyHint = GeographyHint(\"Denver\"),\n                    observedAtUtc = java.time.Instant.parse(\"2026-03-18T00:00:00Z\"),\n                ),\n            )\n            historyService.save(\n                OfferSnapshotRecord(\n                    snapshotId = com.tixmeup.domain.OfferSnapshotId(\"snapshot:perf:1\"),\n                    sourceEventId = com.tixmeup.domain.SourceEventId(\"source:perf:1\"),\n                    performanceId = PerformanceId(\"perf:1\"),\n                    provider = SourceName(\"stubhub\"),\n                    observedAtUtc = java.time.Instant.parse(\"2026-03-18T00:00:00Z\"),\n                    visibleMinPrice = com.tixmeup.domain.moneyOf(\"85.0\", com.tixmeup.domain.CurrencyCode(\"USD\")),\n                    allInMinPrice = null,\n                    availableTicketCount = 4,\n                    state = SnapshotState.AVAILABLE,\n                    supportNotes = emptyList(),\n                ),\n            )\n\n            val snapshots = historyService.findByPerformance(PerformanceId(\"perf:1\"))\n\n            assertEquals(1, snapshots.size)\n            assertEquals(85.0, snapshots.single().visibleMinPrice?.amount?.toDouble())\n        }\n\n    @Test\n    fun `history for performance merges direct and mapped-only snapshots without duplicates`() =\n        runBlocking {\n            val performanceId = PerformanceId(\"perf:mixed\")\n            val directSourceId = SourceEventId(\"source:mixed:direct\")\n            val mappedSourceId = SourceEventId(\"source:mixed:mapped\")\n            val observedAt = Instant.parse(\"2026-03-18T00:00:00Z\")\n\n            insertMixedPerformances()\n            historyService.save(sampleSourceEvent(directSourceId, \"ticketmaster\", observedAt))\n            historyService.save(sampleSourceEvent(mappedSourceId, \"stubhub\", observedAt))\n            historyService.save(offerSnapshot(\"snapshot:mixed:direct\", directSourceId, performanceId, \"ticketmaster\", observedAt))\n            historyService.save(offerSnapshot(\"snapshot:mixed:mapped-null\", mappedSourceId, null, \"stubhub\", observedAt.plusSeconds(60)))\n            historyService.save(\n                offerSnapshot(\n                    snapshotId = \"snapshot:mixed:mapped-other\",\n                    sourceEventId = mappedSourceId,\n                    performanceId = PerformanceId(\"perf:other\"),\n                    provider = \"stubhub\",\n                    observedAtUtc = observedAt.plusSeconds(120),\n                ),\n            )\n            mappingRepository.save(sampleMapping(mappedSourceId, performanceId, observedAt))\n\n            val history = historyService.historyForPerformance(performanceId)\n\n            assertEquals(3, history.size)\n            assertEquals(\n                listOf(observedAt, observedAt.plusSeconds(60), observedAt.plusSeconds(120)),\n                history.map { it.observedAtUtc },\n            )\n            assertEquals(listOf(\"ticketmaster\", \"stubhub\", \"stubhub\"), history.map { it.provider.value })\n        }\n\n    private fun insertMixedPerformances() {\n        dataSource.connection.use { connection ->\n            connection.createStatement().use { statement ->\n                statement.execute(\n                    \"\"\"\n                    insert into performances (\n                        performance_id, title, normalized_title, venue_name, normalized_venue_name,\n                        local_date, local_time, timezone, geography_hint\n                    ) values (\n                        'perf:mixed', 'Mixed Performance', 'mixed performance', 'Mixed Venue', 'mixed venue',\n                        date '2026-03-18', time '19:00:00', 'America/Denver', 'Denver'\n                    ), (\n                        'perf:other', 'Other Performance', 'other performance', 'Other Venue', 'other venue',\n                        date '2026-03-19', time '19:00:00', 'America/Denver', 'Denver'\n                    )\n                    \"\"\".trimIndent(),\n                )\n            }\n        }\n    }\n\n    private fun sampleSourceEvent(\n        sourceEventId: SourceEventId,\n        provider: String,\n        observedAtUtc: Instant,\n    ): SourceEventRecord =\n        SourceEventRecord(\n            sourceEventId = sourceEventId,\n            provider = SourceName(provider),\n            title = \"Mixed Performance\",\n            venueName = \"Mixed Venue\",\n            localDate = LocalDate.parse(\"2026-03-18\"),\n            localTime = LocalTime.parse(\"19:00:00\"),\n            timezone = TimeZoneId(\"America/Denver\"),\n            geographyHint = GeographyHint(\"Denver\"),\n            observedAtUtc = observedAtUtc,\n        )\n\n    private fun offerSnapshot(\n        snapshotId: String,\n        sourceEventId: SourceEventId,\n        performanceId: PerformanceId?,\n        provider: String,\n        observedAtUtc: Instant,\n    ): OfferSnapshotRecord =\n        OfferSnapshotRecord(\n            snapshotId = OfferSnapshotId(snapshotId),\n            sourceEventId = sourceEventId,\n            performanceId = performanceId,\n            provider = SourceName(provider),\n            observedAtUtc = observedAtUtc,\n            visibleMinPrice = moneyOf(\"100.0\", CurrencyCode(\"USD\")),\n            allInMinPrice = null,\n            availableTicketCount = 4,\n            state = SnapshotState.AVAILABLE,\n            supportNotes = emptyList(),\n        )\n\n    private fun sampleMapping(\n        sourceEventId: SourceEventId,\n        performanceId: PerformanceId,\n        matchedAtUtc: Instant,\n    ): SourceEventMappingRecord =\n        SourceEventMappingRecord(\n            sourceEventId = sourceEventId,\n            performanceId = performanceId,\n            confidence = ConfidenceScore(0.9),\n            disposition = MatchDisposition.AUTO_MATCH,\n            matchedAtUtc = matchedAtUtc,\n            reason = \"Deterministic mapping for test fixture.\",\n        )\n}\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_18","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,180p' scripts/explain-cache-miss-paths.sh\"","aggregated_output":"#!/usr/bin/env bash\n\nset -euo pipefail\n\nif ! command -v psql >/dev/null 2>&1; then\n  echo \"psql is required to run cache miss-path EXPLAIN ANALYZE\" >&2\n  exit 1\nfi\n\nDATABASE_URL=\"${DATABASE_URL:-${TIXMEUP_DATABASE_URL:-}}\"\nif [[ -z \"${DATABASE_URL}\" ]]; then\n  echo \"Set DATABASE_URL or TIXMEUP_DATABASE_URL to a Postgres connection string.\" >&2\n  exit 1\nfi\n\n# PERFORMANCE_ID and SOURCE_EVENT_ID are intended for trusted operator use in this diagnostic script.\n# They are interpolated into SQL below, so do not pass untrusted values here.\n\nrun_sql() {\n  psql \"${DATABASE_URL}\" -v ON_ERROR_STOP=1 -At -c \"$1\"\n}\n\nsample_performance_id=\"${PERFORMANCE_ID:-$(run_sql \"select performance_id from source_event_mappings group by performance_id order by count(*) desc, performance_id asc limit 1;\")}\"\nif [[ -z \"${sample_performance_id}\" ]]; then\n  echo \"No performance_id found in source_event_mappings. Seed or point the script at a populated database.\" >&2\n  exit 1\nfi\n\nsample_source_event_id=\"${SOURCE_EVENT_ID:-$(run_sql \"select source_event_id from source_event_mappings where performance_id = '${sample_performance_id}' order by matched_at_utc asc nulls last, source_event_id asc limit 1;\")}\"\nif [[ -z \"${sample_source_event_id}\" ]]; then\n  echo \"No source_event_id found for performance_id ${sample_performance_id}.\" >&2\n  exit 1\nfi\n\necho \"Using performance_id=${sample_performance_id}\"\necho \"Using source_event_id=${sample_source_event_id}\"\n\nexplain() {\n  local title=\"$1\"\n  local sql=\"$2\"\n  echo\n  echo \"=== ${title} ===\"\n  psql \"${DATABASE_URL}\" -v ON_ERROR_STOP=1 -c \"EXPLAIN (ANALYZE, BUFFERS, VERBOSE) ${sql}\"\n}\n\nexplain \\\n  \"source_event_mappings by performance (event intelligence + history miss path)\" \\\n  \"select source_event_id, performance_id, confidence, disposition, matched_at_utc, reason\n     from source_event_mappings\n    where performance_id = '${sample_performance_id}'\n    order by matched_at_utc asc, source_event_id asc\"\n\nexplain \\\n  \"offer_snapshots by source_event_id (event intelligence history fan-out)\" \\\n  \"select se.source_event_id, os.provider, se.title, se.venue_name, os.observed_at_utc,\n          os.visible_min_amount, os.visible_min_currency, os.all_in_min_amount, os.all_in_min_currency,\n          os.available_ticket_count, os.state, os.support_notes_json\n     from offer_snapshots os\n     join source_events se on se.source_event_id = os.source_event_id\n    where os.source_event_id = '${sample_source_event_id}'\n    order by os.observed_at_utc asc\"\n\nexplain \\\n  \"offer_snapshots by performance (event history miss path)\" \\\n  \"select snapshot_id, source_event_id, performance_id, provider, observed_at_utc,\n          visible_min_amount, visible_min_currency, all_in_min_amount, all_in_min_currency,\n          available_ticket_count, state, support_notes_json\n     from offer_snapshots\n    where performance_id = '${sample_performance_id}'\n    order by observed_at_utc asc\"\n\nexplain \\\n  \"historyForPerformance (direct + mapped union all, miss path)\" \\\n  \"select se.source_event_id, os.provider, se.title, se.venue_name, os.observed_at_utc,\n          os.visible_min_amount, os.visible_min_currency, os.all_in_min_amount, os.all_in_min_currency,\n          os.available_ticket_count, os.state, os.support_notes_json\n     from offer_snapshots os\n     join source_events se on se.source_event_id = os.source_event_id\n    where os.performance_id = '${sample_performance_id}'\n   union all\n   select se.source_event_id, os.provider, se.title, se.venue_name, os.observed_at_utc,\n          os.visible_min_amount, os.visible_min_currency, os.all_in_min_amount, os.all_in_min_currency,\n          os.available_ticket_count, os.state, os.support_notes_json\n     from source_event_mappings sem\n     join offer_snapshots os on os.source_event_id = sem.source_event_id\n     join source_events se on se.source_event_id = os.source_event_id\n    where sem.performance_id = '${sample_performance_id}'\n      and os.performance_id is distinct from '${sample_performance_id}'\n    order by observed_at_utc asc, provider asc, source_event_id asc\"\n\nexplain \\\n  \"signal_snapshots by performance (event timeline miss path)\" \\\n  \"select *\n     from signal_snapshots\n    where performance_id = '${sample_performance_id}'\n    order by observed_at_utc desc\"\n\nexplain \\\n  \"market_events by performance (event timeline miss path)\" \\\n  \"select *\n     from market_events\n    where performance_id = '${sample_performance_id}'\n    order by observed_at_utc desc\"\n","exit_code":0,"status":"completed"}}
