{"type":"item.completed","item":{"id":"item_44","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,160p' integration-tests/src/test/kotlin/com/tixmeup/integration/RuntimeScaleProfileDAcceptanceTest.kt\"","aggregated_output":"package com.tixmeup.integration\n\nimport com.tixmeup.domain.SourceEventId\nimport com.tixmeup.domain.SourceName\nimport com.tixmeup.testutils.PostgresTestSupport\nimport kotlinx.coroutines.runBlocking\nimport org.junit.jupiter.api.Assertions.assertEquals\nimport org.junit.jupiter.api.Assertions.assertTrue\nimport org.junit.jupiter.api.Assumptions.assumeTrue\nimport org.junit.jupiter.api.Tag\nimport org.junit.jupiter.api.Test\nimport java.net.http.HttpClient\n\n@Tag(\"runtime-scale\")\nclass RuntimeScaleProfileDAcceptanceTest {\n    @Test\n    @Suppress(\"LongMethod\")\n    fun `profile D captures miss path explain artifacts for hot event read keys`() {\n        runBlocking {\n            assumeProfile(RuntimeScaleProfileId.D)\n            assumeTrue(PostgresTestSupport.isAvailable(), PostgresTestSupport.skipReason())\n\n            val profile = RuntimeScaleSupport.profile(RuntimeScaleProfileId.D)\n            val connectionInfo = prepareDatabase()\n            val catalog = RuntimeScaleSupport.generateCatalog(profile.performanceCount)\n            val providerResolutionAttempts = concurrentProviderResolutionAttempts()\n\n            createDemoRuntime(\n                connectionInfo,\n                RuntimeScaleSupport.appConfig(catalog.events, providerResolutionAttempts),\n            ).use { runtime ->\n                RuntimeScaleSupport.seedBulk(runtime.graph, catalog, profile.snapshotsPerSourceEvent)\n                RuntimeScaleSupport.analyzeRuntimeScaleReadTables(connectionInfo)\n                RuntimeScaleSupport.clearCacheMetrics(connectionInfo)\n\n                RuntimeScaleSupport.startServer(runtime).use { server ->\n                    val client = HttpClient.newHttpClient()\n                    val requestResults =\n                        buildList {\n                            catalog.topSlugs.take(profile.hottestPerformanceCount).forEach { slug ->\n                                add(RuntimeScaleSupport.request(client, server.baseUrl, \"/event-intelligence/${slug.value}\"))\n                                add(\n                                    RuntimeScaleSupport.request(\n                                        client,\n                                        server.baseUrl,\n                                        \"/event-intelligence/${slug.value}/history?window=LAST_24_HOURS\",\n                                    ),\n                                )\n                            }\n                        }\n\n                    val sampleEvent = catalog.events.first()\n                    val explainMappings =\n                        RuntimeScaleSupport.explainSourceEventMappings(connectionInfo, sampleEvent.performanceId)\n                    val explainHistory =\n                        RuntimeScaleSupport.explainHistoryByPerformance(connectionInfo, sampleEvent.performanceId)\n                    val eventIntelligenceP95 =\n                        RuntimeScaleSupport.percentile(\n                            requestResults\n                                .filter {\n                                    it.routeFamily.startsWith(\"/event-intelligence/\") &&\n                                        !it.routeFamily.endsWith(\"/history\") &&\n                                        !it.routeFamily.endsWith(\"/seo\")\n                                }.map { it.latencyMillis },\n                            0.95,\n                        )\n                    val eventHistoryP95 =\n                        RuntimeScaleSupport.percentile(\n                            requestResults.filter { it.routeFamily.endsWith(\"/history\") }.map { it.latencyMillis },\n                            0.95,\n                        )\n                    val requestSummary = RuntimeScaleSupport.summarizeRequests(requestResults)\n                    val providerResolutionSummary = summarizeProviderResolutionAttempts(providerResolutionAttempts)\n\n                    RuntimeScaleSupport.writeArtifact(RuntimeScaleProfileId.D, \"explain-source-event-mappings.txt\", explainMappings)\n                    RuntimeScaleSupport.writeArtifact(RuntimeScaleProfileId.D, \"explain-history-by-performance.txt\", explainHistory)\n                    RuntimeScaleSupport.writeArtifact(\n                        RuntimeScaleProfileId.D,\n                        \"summary.txt\",\n                        buildString {\n                            appendLine(requestSummary)\n                            appendLine(\"eventIntelligenceP95=${eventIntelligenceP95}ms\")\n                            appendLine(\"eventHistoryP95=${eventHistoryP95}ms\")\n                            appendLine(providerResolutionSummary)\n                        },\n                    )\n                    assertTrue(\n                        explainMappings.contains(\"source_event_mappings_performance_idx\"),\n                        \"Expected source_event_mappings_performance_idx in mappings explain plan.\\n${planExcerpt(explainMappings)}\",\n                    )\n                    assertTrue(\n                        explainHistory.contains(\"offer_snapshots_performance_observed_idx\"),\n                        \"Expected offer_snapshots_performance_observed_idx in history explain plan.\\n${planExcerpt(explainHistory)}\",\n                    )\n                    assertTrue(\n                        requestResults.all { it.statusCode == 200 },\n                        \"Expected all hot event reads to return 200.\\n$requestSummary\",\n                    )\n                    assertTrue(\n                        eventIntelligenceP95 < latencyBudgetMillis(),\n                        \"Expected event intelligence P95 under ${latencyBudgetMillis()}ms \" +\n                            \"but was ${eventIntelligenceP95}ms.\\n$requestSummary\",\n                    )\n                    assertTrue(\n                        eventHistoryP95 < latencyBudgetMillis(),\n                        \"Expected event history P95 under ${latencyBudgetMillis()}ms \" +\n                            \"but was ${eventHistoryP95}ms.\\n$requestSummary\",\n                    )\n                    assertEquals(\n                        0,\n                        providerResolutionAttempts.size,\n                        \"Expected no provider resolution attempts.\\n$providerResolutionSummary\",\n                    )\n                }\n            }\n        }\n    }\n\n    private fun prepareDatabase(): com.tixmeup.testutils.PostgresConnectionInfo {\n        val dataSource = PostgresTestSupport.dataSource()\n        val connectionInfo = PostgresTestSupport.connectionInfo()\n        PostgresTestSupport.resetSchema(dataSource)\n        PostgresTestSupport.applyMigrations(dataSource)\n        return connectionInfo\n    }\n\n    private fun assumeProfile(profileId: RuntimeScaleProfileId) {\n        assumeTrue(RuntimeScaleSupport.activeProfiles().contains(profileId), \"Profile ${profileId.name} is not enabled\")\n    }\n\n    private fun latencyBudgetMillis(): Long =\n        when (RuntimeScaleSupport.mode()) {\n            RuntimeScaleMode.SMOKE -> 5_000\n            RuntimeScaleMode.TARGET -> 10_000\n        }\n\n    private fun planExcerpt(\n        explainPlan: String,\n        maxLines: Int = 20,\n    ): String = explainPlan.lineSequence().take(maxLines).joinToString(System.lineSeparator())\n\n    private fun summarizeProviderResolutionAttempts(providerResolutionAttempts: Collection<Pair<SourceName, SourceEventId>>): String =\n        if (providerResolutionAttempts.isEmpty()) {\n            \"providerResolutionAttempts=0\"\n        } else {\n            buildString {\n                appendLine(\"providerResolutionAttempts=${providerResolutionAttempts.size}\")\n                providerResolutionAttempts.take(10).forEach { (provider, sourceEventId) ->\n                    appendLine(\"${provider.value}:${sourceEventId.value}\")\n                }\n                if (providerResolutionAttempts.size > 10) {\n                    appendLine(\"providerResolutionAttemptsTruncated=true\")\n                }\n            }.trimEnd()\n        }\n}\n","exit_code":0,"status":"completed"}}
