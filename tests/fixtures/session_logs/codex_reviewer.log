{"type":"item.completed","item":{"id":"item_21","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,120p' db/migrations/V1__performances_and_observations.sql\"","aggregated_output":"create table if not exists performances (\n    performance_id text primary key,\n    title text not null,\n    normalized_title text not null,\n    venue_name text not null,\n    normalized_venue_name text not null,\n    local_date date not null,\n    local_time time,\n    timezone text,\n    geography_hint text,\n    created_at timestamptz not null default now()\n);\n\ncreate unique index if not exists performances_identity_idx\n    -- NULL local_time is intentionally coalesced to midnight to prevent \"unknown time\" duplicates\n    on performances (normalized_title, normalized_venue_name, local_date, coalesce(local_time, time '00:00:00'));\n\ncreate table if not exists observation_batches (\n    batch_id text primary key,\n    provider text not null,\n    observed_at_utc timestamptz not null\n);\n\ncreate table if not exists source_events (\n    source_event_id text primary key,\n    provider text not null,\n    title text not null,\n    venue_name text not null,\n    local_date date,\n    local_time time,\n    timezone text,\n    geography_hint text,\n    observed_at_utc timestamptz not null\n);\n\ncreate index if not exists source_events_provider_observed_idx\n    on source_events (provider, observed_at_utc desc);\n\ncreate table if not exists batch_source_events (\n    batch_id text not null references observation_batches(batch_id) on delete cascade,\n    source_event_id text not null references source_events(source_event_id) on delete cascade,\n    primary key (batch_id, source_event_id)\n);\n\ncreate table if not exists offer_snapshots (\n    snapshot_id text primary key,\n    source_event_id text not null references source_events(source_event_id) on delete cascade,\n    performance_id text references performances(performance_id),\n    provider text not null,\n    observed_at_utc timestamptz not null,\n    visible_min_amount numeric(12, 2),\n    visible_min_currency text,\n    all_in_min_amount numeric(12, 2),\n    all_in_min_currency text,\n    available_ticket_count integer,\n    state text not null,\n    support_notes_json jsonb not null\n);\n\ncreate index if not exists offer_snapshots_source_event_observed_idx\n    on offer_snapshots (source_event_id, observed_at_utc desc);\n\ncreate index if not exists offer_snapshots_performance_observed_idx\n    on offer_snapshots (performance_id, observed_at_utc desc);\n\ncreate index if not exists offer_snapshots_provider_observed_idx\n    on offer_snapshots (provider, observed_at_utc desc);\n\ncreate table if not exists poll_targets (\n    poll_target_id text primary key,\n    performance_id text not null references performances(performance_id) on delete cascade,\n    tier text not null,\n    next_poll_at_utc timestamptz,\n    last_observed_at_utc timestamptz,\n    rationale text\n);\n\ncreate index if not exists poll_targets_performance_idx\n    on poll_targets (performance_id);\n","exit_code":0,"status":"completed"}}
