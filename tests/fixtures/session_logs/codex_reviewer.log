ationBatchRecord? = synchronized(lock) { batches[batchId] }\n\n    override suspend fun save(record: SourceEventRecord) {\n        sourceEvents[record.sourceEventId] = record\n    }\n\n    override suspend fun find(sourceEventId: SourceEventId): SourceEventRecord? = synchronized(lock) { sourceEvents[sourceEventId] }\n\n    override suspend fun save(snapshot: OfferSnapshotRecord) {\n        snapshots[snapshot.snapshotId] = snapshot\n    }\n\n    override suspend fun findByPerformance(performanceId: PerformanceId): List<OfferSnapshotRecord> =\n        synchronized(lock) {\n","exit_code":0,"status":"completed"}}
