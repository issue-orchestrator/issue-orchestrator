#!/bin/bash
# Pre-push hook: Run pyright type checking before pushing

echo "Running pyright type check..."

# Activate venv if it exists
if [ -d ".venv" ]; then
    source .venv/bin/activate
fi

# Run pyright
pyright src/

if [ $? -ne 0 ]; then
    echo ""
    echo "❌ Type check failed. Fix errors before pushing."
    exit 1
fi

echo "✅ Type check passed."
exit 0
