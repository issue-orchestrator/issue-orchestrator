#!/bin/bash
# Pre-push hook: Run typecheck + architecture guardrails before pushing

echo "Running pyright type check..."

# Activate venv if it exists
if [ -d ".venv" ]; then
    source .venv/bin/activate
fi

# Run pyright
pyright src/

if [ $? -ne 0 ]; then
    echo ""
    echo "❌ Type check failed. Fix errors before pushing."
    exit 1
fi

echo "✅ Type check passed."

echo "Running architecture guardrails..."
if command -v lint-imports >/dev/null 2>&1; then
    lint-imports
else
    echo "❌ lint-imports not found. Install: pip install import-linter"
    exit 1
fi

python tools/check_arch_guardrails.py src
echo "✅ Architecture guardrails passed."
exit 0
