#!/usr/bin/env bash
set -euo pipefail

# Canonical local publish gate.
# Mirrors the required PR coverage through the cache-aware prepush_check path.

if [ -x ".venv/bin/python" ]; then
  .venv/bin/python -m issue_orchestrator.entrypoints.cli_tools.prepush_check -v
elif command -v python3 >/dev/null 2>&1; then
  python3 -m issue_orchestrator.entrypoints.cli_tools.prepush_check -v
else
  echo "python3 not found; cannot run pre-push validation" >&2
  exit 1
fi
