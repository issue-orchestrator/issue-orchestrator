# Frozen source snapshot written by scripts/start_control_center.sh at
# CC launch to immunise the serving path against base-repo branch drift
# (see src/issue_orchestrator/infra/cc_snapshot.py). Ephemeral per-run.
.control-center-snapshot/

# Project specific - local state files
.issue-orchestrator/validation/
.issue-orchestrator/completion.json
.issue-orchestrator/completion-*.json
.issue-orchestrator/state_machines.json
.issue-orchestrator/lock.json
.issue-orchestrator/state/
.issue-orchestrator/session.log
.issue-orchestrator/pane.log
# Pre-push hook audit logs (written by managed wrappers during every push).
# .githooks/ itself is tracked — only the runtime log file is noise.
.githooks/pre-push.log
.githooks/*.log
.issue-orchestrator/session-identity-*.json
.issue-orchestrator/session-latest.json
.issue-orchestrator/failure-diagnostic-*.json
.issue-orchestrator/logs/
.issue-orchestrator/*.db
.issue-orchestrator/sessions/
.issue-orchestrator/diagnostics/
.issue-orchestrator/safety-state.json
.issue-orchestrator/ai-gate-state.json
.issue-orchestrator/backups/
.issue-orchestrator/timeline.sqlite
.issue-orchestrator/*.sqlite
.agent-done-marker
/TODO.md

# Review-exchange / persistent-pair runtime outputs. These are written by the
# orchestrator and the live agent sessions during a review exchange; they must
# never enter an agent branch or they break the reviewer-worktree fast-forward
# checkout and bloat the review diff (see #6659).
.issue-orchestrator/persistent-pairs/
.issue-orchestrator/review-feedback/
.issue-orchestrator/review-response.json
.issue-orchestrator/review-report.md
.issue-orchestrator/review-exchange-turn-prompt.md
.issue-orchestrator/tool-homes/

# Keep .issue-orchestrator/config/ tracked - it's project configuration
.validate/
.venv
.venv-semgrep

# MCP server config (local to each developer)
.mcp.json

# Playwright MCP local state
.playwright-mcp/

# Java version manager
.java-version

# Worktrees for development
worktrees/

# Local generated documentation previews
.preview/

# Lint / type-check caches
.ruff_cache/
.import_linter_cache/

# Credentials / secrets — defense-in-depth (none are committed; prevents accidents)
.env
.env.*
*.pem
*.key
id_rsa
.pypirc
.npmrc
