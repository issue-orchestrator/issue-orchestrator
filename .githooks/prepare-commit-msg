#!/bin/sh
set -eu

message_file=${1:-}
if [ -z "$message_file" ]; then
  echo "prepare-commit-msg: missing commit message file path" >&2
  exit 1
fi

is_blank() {
  [ -z "$(printf '%s' "$1" | tr -d '[:space:]')" ]
}

set_signoff_from_ident() {
  ident=$1
  signoff_name=${ident%% <*}
  parsed_email=${ident#*<}
  if [ "$parsed_email" != "$ident" ]; then
    signoff_email=${parsed_email%%>*}
  else
    signoff_email=
  fi
}

signoff_name=
signoff_email=

# During git am/cherry-pick, git var can still report the committer config.
# Read Git's in-progress author metadata first for those flows.
applypatch_info=$(git rev-parse --git-path rebase-apply/info 2>/dev/null || true)
if [ -f "$applypatch_info" ]; then
  signoff_name=$(sed -n 's/^Author: //p' "$applypatch_info" | sed -n '1p')
  signoff_email=$(sed -n 's/^Email: //p' "$applypatch_info" | sed -n '1p')
fi

cherry_pick_head=$(git rev-parse --git-path CHERRY_PICK_HEAD 2>/dev/null || true)
if { is_blank "$signoff_name" || is_blank "$signoff_email"; } && [ -f "$cherry_pick_head" ]; then
  author_ident=$(git show -s --format='%an <%ae>' CHERRY_PICK_HEAD 2>/dev/null || true)
  set_signoff_from_ident "$author_ident"
fi

if is_blank "$signoff_name" || is_blank "$signoff_email"; then
  config_name=$(git config user.name || true)
  config_email=$(git config user.email || true)
  if ! {
    is_blank "${GIT_AUTHOR_NAME:-}" &&
      is_blank "${GIT_AUTHOR_EMAIL:-}" &&
      is_blank "$config_name" &&
      is_blank "$config_email"
  }; then
    author_ident=$(git var GIT_AUTHOR_IDENT 2>/dev/null || true)
    set_signoff_from_ident "$author_ident"
  fi
fi

if is_blank "$signoff_name" || is_blank "$signoff_email"; then
  echo "prepare-commit-msg: DCO sign-off requires a git author name and email." >&2
  echo "prepare-commit-msg: configure git user.name/user.email or set GIT_AUTHOR_NAME/GIT_AUTHOR_EMAIL." >&2
  exit 1
fi

exec git interpret-trailers \
  --if-exists addIfDifferent \
  --trailer "Signed-off-by: $signoff_name <$signoff_email>" \
  --in-place "$message_file"
