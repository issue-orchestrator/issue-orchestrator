{
  "name": "issue-orchestrator",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.13-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "22"
    },
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "forwardPorts": [19080, 19081, 8080],
  "portsAttributes": {
    "19080": {
      "label": "Issue Orchestrator Control Center",
      "onAutoForward": "openBrowserOnce",
      "protocol": "http"
    },
    "19081": {
      "label": "Issue Orchestrator Control API",
      "onAutoForward": "silent",
      "protocol": "http"
    },
    "8080": {
      "label": "Issue Orchestrator Engine Dashboard",
      "onAutoForward": "silent",
      "protocol": "http"
    }
  },
  "postCreateCommand": "make worktree-setup && npm install -g @openai/codex@0.114.0",
  "hostRequirements": {
    "cpus": 4,
    "memory": "8gb",
    "storage": "32gb"
  },
  "customizations": {
    "codespaces": {
      "openFiles": [
        "docs/user/codespaces.md"
      ]
    },
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "ms-playwright.playwright",
        "github.vscode-pull-request-github"
      ]
    }
  }
}
