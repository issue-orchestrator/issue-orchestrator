# Orchestrator safety rules for Codex CLI
# These rules prevent agents from bypassing pre-push hooks
# Install to: ~/.codex/rules/orchestrator.rules

# Block git push --no-verify (and variants)
prefix_rule(
    pattern = ["git", "push", "--no-verify"],
    decision = "forbidden",
    justification = "Pre-push hooks must run. Use 'git push' without --no-verify.",
    match = ["git push --no-verify origin main"],
    not_match = ["git push origin main"],
)

prefix_rule(
    pattern = ["git", "push", ["origin", "upstream"], "--no-verify"],
    decision = "forbidden",
    justification = "Pre-push hooks must run. Use 'git push' without --no-verify.",
)

# Block git commit --no-verify
prefix_rule(
    pattern = ["git", "commit", "--no-verify"],
    decision = "forbidden",
    justification = "Pre-commit hooks must run. Use 'git commit' without --no-verify.",
    match = ["git commit --no-verify -m 'test'"],
    not_match = ["git commit -m 'test'"],
)

# Block git commit -n (shorthand for --no-verify)
prefix_rule(
    pattern = ["git", "commit", "-n"],
    decision = "forbidden",
    justification = "-n is shorthand for --no-verify. Use 'git commit' without -n.",
)

# Block disabling hooks via core.hooksPath
prefix_rule(
    pattern = ["git", "-c", "core.hooksPath=/dev/null"],
    decision = "forbidden",
    justification = "Disabling hooks via core.hooksPath is forbidden.",
)

prefix_rule(
    pattern = ["git", "config", "core.hooksPath", "/dev/null"],
    decision = "forbidden",
    justification = "Configuring core.hooksPath=/dev/null is forbidden.",
)

prefix_rule(
    pattern = ["git", "config", "--local", "core.hooksPath", "/dev/null"],
    decision = "forbidden",
    justification = "Configuring core.hooksPath=/dev/null is forbidden.",
)

prefix_rule(
    pattern = ["git", "config", "--worktree", "core.hooksPath", "/dev/null"],
    decision = "forbidden",
    justification = "Configuring core.hooksPath=/dev/null is forbidden.",
)

# Block gh pr merge - agents cannot merge PRs
prefix_rule(
    pattern = ["gh", "pr", "merge"],
    decision = "forbidden",
    justification = "Agents cannot merge PRs. Only humans can merge.",
    match = ["gh pr merge 123", "gh pr merge 123 --squash"],
    not_match = ["gh pr create", "gh pr view 123"],
)

# Block gh api calls - must be forbidden, not prompt
# REASON: Codex CLI has --full-auto, --ask-for-approval=never, and --yolo flags
# that skip interactive prompts. Using "prompt" would silently allow merge
# requests in CI/automation environments, breaking the "agents cannot merge"
# guardrail. Since prefix_rule cannot target specific endpoints (no regex),
# we block all gh api calls to ensure safety.
prefix_rule(
    pattern = ["gh", "api"],
    decision = "forbidden",
    justification = "gh api calls are forbidden. Use gh pr/issue commands instead. Merge via API is never allowed.",
    match = ["gh api repos/owner/repo/pulls/123/merge", "gh api /repos/o/r/issues"],
    not_match = ["gh pr create", "gh issue list"],
)
