#!/bin/bash
# Pre-push hook: Validates agent code quality
# Installed by issue-orchestrator in agent worktrees

set -e

# Enforce dirty-tree policy from YAML before any push-time checks.
#
# Python resolution for the orchestrator helper module. The orchestrator is
# the only legitimate invoker of this push (agents are blocked from pushing
# directly), and it exports ISSUE_ORCHESTRATOR_PYTHON pointing at the
# interpreter where the ``issue_orchestrator`` package is importable.
# Preferring that over ambient lookups lets the hook work in any target
# repo (Kotlin, Node, pure-data, etc.) without the target having to install
# the orchestrator package into its own venv. The legacy lookups stay as
# fallbacks so a human running ``git push`` standalone in an orchestrator
# checkout still works.
PYTHON_BIN=""
if [ -n "${ISSUE_ORCHESTRATOR_PYTHON:-}" ] && [ -x "$ISSUE_ORCHESTRATOR_PYTHON" ]; then
    PYTHON_BIN="$ISSUE_ORCHESTRATOR_PYTHON"
elif [ -x ".venv/bin/python" ]; then
    PYTHON_BIN=".venv/bin/python"
elif command -v python3 >/dev/null 2>&1; then
    PYTHON_BIN="python3"
fi

if [ -z "$PYTHON_BIN" ]; then
    echo "ERROR: Python not found; cannot run dirty-tree guard." >&2
    echo "  - If the orchestrator invoked this push: bootstrap should export" >&2
    echo "    ISSUE_ORCHESTRATOR_PYTHON. Restart the orchestrator from a shell" >&2
    echo "    where it can find its own venv." >&2
    echo "  - If you ran 'git push' yourself: install python3, or activate the" >&2
    echo "    orchestrator's .venv before pushing." >&2
    exit 1
fi

if ! "$PYTHON_BIN" -m issue_orchestrator.entrypoints.cli_tools.prepush_check --dirty-only -v; then
    echo "ERROR: Dirty-tree guard failed." >&2
    exit 1
fi

# ============================================================================
# GUARDRAIL: Block test-skipping patterns
# ============================================================================
# Agents must NOT use @Disabled, @Ignore, or assumeTrue to skip failing tests.
# These patterns let bugs slip through by avoiding tests instead of fixing them.

check_test_skipping() {
    # Get diff of changes being pushed (comparing to remote or main)
    local diff_output
    diff_output=$(git diff origin/main...HEAD --unified=0 -- '*.kt' '*.java' 2>/dev/null || git diff main...HEAD --unified=0 -- '*.kt' '*.java' 2>/dev/null || echo "")

    if [[ -z "$diff_output" ]]; then
        return 0  # No diff available, skip check
    fi

    # Look for ADDED lines (start with +) containing forbidden patterns
    local forbidden_patterns="@Disabled|@Ignore|assumeTrue|assumeFalse"
    local violations
    violations=$(echo "$diff_output" | grep -E "^\+.*($forbidden_patterns)" | grep -v "^+++" || true)

    if [[ -n "$violations" ]]; then
        echo ""
        echo "╔════════════════════════════════════════════════════════════════╗"
        echo "║  ❌ ERROR: Test-skipping patterns detected                     ║"
        echo "╠════════════════════════════════════════════════════════════════╣"
        echo "║  You added code that skips tests. This is NOT allowed.         ║"
        echo "║                                                                ║"
        echo "║  Forbidden patterns:                                           ║"
        echo "║    - @Disabled / @Ignore (skips test entirely)                 ║"
        echo "║    - assumeTrue / assumeFalse (skips at runtime)               ║"
        echo "║                                                                ║"
        echo "║  If tests fail, FIX THEM. Do not skip them.                    ║"
        echo "╚════════════════════════════════════════════════════════════════╝"
        echo ""
        echo "Violations found:"
        echo "$violations"
        echo ""
        exit 1
    fi
}

# Run the test-skipping check
check_test_skipping

# All validations passed
exit 0
