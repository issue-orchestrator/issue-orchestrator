#!/bin/bash
# gh-wrapper - intercepts gh commands to block unauthorized operations
#
# This wrapper prevents agents from bypassing agent-done by using gh directly.
# Only agent-done knows the authorization token.

# Check if this is a pr create command
if [[ "$1" == "pr" && "$2" == "create" ]]; then
    # Check for authorization token (only agent-done sets this)
    if [[ "$ORCHESTRATOR_GH_AUTH" != "agent-done-authorized" ]]; then
        echo "" >&2
        echo "╔════════════════════════════════════════════════════════════════╗" >&2
        echo "║  ❌ ERROR: Direct 'gh pr create' is BLOCKED                    ║" >&2
        echo "╠════════════════════════════════════════════════════════════════╣" >&2
        echo "║                                                                ║" >&2
        echo "║  You MUST use 'agent-done' to create PRs.                      ║" >&2
        echo "║  This ensures proper tracking and code review workflow.        ║" >&2
        echo "║                                                                ║" >&2
        echo "║  ✅ Correct usage:                                             ║" >&2
        echo "║     agent-done completed \\                                     ║" >&2
        echo "║       --implementation \"What you implemented\" \\                ║" >&2
        echo "║       --problems \"None\"                                        ║" >&2
        echo "║                                                                ║" >&2
        echo "╚════════════════════════════════════════════════════════════════╝" >&2
        echo "" >&2
        exit 1
    fi
fi

# Check if this is a pr edit command with label manipulation
if [[ "$1" == "pr" && "$2" == "edit" ]]; then
    # Check if --add-label or --remove-label is in the arguments
    for arg in "$@"; do
        if [[ "$arg" == "--add-label" || "$arg" == "--remove-label" ]]; then
            # Check for authorization token (only agent-done sets this)
            if [[ "$ORCHESTRATOR_GH_AUTH" != "agent-done-authorized" ]]; then
                echo "" >&2
                echo "╔════════════════════════════════════════════════════════════════╗" >&2
                echo "║  ❌ ERROR: Direct label manipulation is BLOCKED                ║" >&2
                echo "╠════════════════════════════════════════════════════════════════╣" >&2
                echo "║                                                                ║" >&2
                echo "║  You MUST use 'agent-done' for label management.               ║" >&2
                echo "║  This ensures proper workflow state tracking.                  ║" >&2
                echo "║                                                                ║" >&2
                echo "║  ✅ For code reviewers:                                        ║" >&2
                echo "║     agent-done approved --summary \"Review summary\"             ║" >&2
                echo "║     agent-done changes_requested --issues \"Issues found\"       ║" >&2
                echo "║                                                                ║" >&2
                echo "║  ✅ For work agents:                                           ║" >&2
                echo "║     agent-done completed --implementation \"...\" --problems ... ║" >&2
                echo "║     agent-done blocked --reason \"...\" --attempted \"...\"        ║" >&2
                echo "║                                                                ║" >&2
                echo "╚════════════════════════════════════════════════════════════════╝" >&2
                echo "" >&2
                exit 1
            fi
            break
        fi
    done
fi

# Find and exec real gh (search common locations)
for gh_path in /opt/homebrew/bin/gh /usr/local/bin/gh /usr/bin/gh; do
    if [[ -x "$gh_path" ]]; then
        exec "$gh_path" "$@"
    fi
done

# Fallback: try to find gh in PATH (excluding this wrapper)
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REAL_GH=$(which -a gh 2>/dev/null | grep -v "$SCRIPT_DIR" | head -1)
if [[ -x "$REAL_GH" ]]; then
    exec "$REAL_GH" "$@"
fi

echo "ERROR: Could not find real gh executable" >&2
exit 1
