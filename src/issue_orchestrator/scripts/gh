#!/bin/bash
# gh-wrapper - intercepts gh commands to enforce read-only access for agents
#
# WHITELIST APPROACH: Only explicitly allowed commands pass through.
# Everything else is blocked unless authorized via ORCHESTRATOR_GH_AUTH.
#
# Agents should use 'coding-done'/'reviewer-done' for any write operations.

set -euo pipefail

# === WHITELISTED READ-ONLY COMMANDS ===
# These commands are safe - they only read data, never modify.

is_allowed_command() {
    local cmd="$1"
    local subcmd="${2:-}"

    case "$cmd" in
        # PR read operations
        pr)
            case "$subcmd" in
                view|list|diff|checks|status) return 0 ;;
            esac
            ;;
        # Issue read operations
        issue)
            case "$subcmd" in
                view|list|status) return 0 ;;
            esac
            ;;
        # Repo read operations
        repo)
            case "$subcmd" in
                view|list|clone) return 0 ;;
            esac
            ;;
        # Search (read-only)
        search)
            case "$subcmd" in
                repos|issues|prs|commits|code) return 0 ;;
            esac
            ;;
        # Status/auth checks (read-only)
        auth)
            case "$subcmd" in
                status) return 0 ;;
            esac
            ;;
        status)
            return 0
            ;;
        # Browse (just opens browser, harmless)
        browse)
            return 0
            ;;
        # Help
        help|--help|-h)
            return 0
            ;;
        # Version
        version|--version)
            return 0
            ;;
    esac

    return 1
}

# === CHECK AUTHORIZATION ===

# If authorized by completion command, allow everything
if [[ "${ORCHESTRATOR_GH_AUTH:-}" == "agent-done-authorized" ]]; then
    if [[ -n "${ORCHESTRATOR_REAL_GH:-}" && -x "${ORCHESTRATOR_REAL_GH}" ]]; then
        exec "${ORCHESTRATOR_REAL_GH}" "$@"
    fi
    # Find and exec real gh
    for gh_path in /opt/homebrew/bin/gh /usr/local/bin/gh /usr/bin/gh; do
        if [[ -x "$gh_path" ]]; then
            exec "$gh_path" "$@"
        fi
    done

    SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    REAL_GH=$(which -a gh 2>/dev/null | grep -v "$SCRIPT_DIR" | head -1)
    if [[ -x "$REAL_GH" ]]; then
        exec "$REAL_GH" "$@"
    fi

    echo "ERROR: Could not find real gh executable" >&2
    exit 1
fi

# === CHECK IF COMMAND IS ALLOWED ===

cmd="${1:-}"
subcmd="${2:-}"

if is_allowed_command "$cmd" "$subcmd"; then
    if [[ -n "${ORCHESTRATOR_REAL_GH:-}" && -x "${ORCHESTRATOR_REAL_GH}" ]]; then
        exec "${ORCHESTRATOR_REAL_GH}" "$@"
    fi
    # Allowed - pass through to real gh
    for gh_path in /opt/homebrew/bin/gh /usr/local/bin/gh /usr/bin/gh; do
        if [[ -x "$gh_path" ]]; then
            exec "$gh_path" "$@"
        fi
    done

    SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    REAL_GH=$(which -a gh 2>/dev/null | grep -v "$SCRIPT_DIR" | head -1)
    if [[ -x "$REAL_GH" ]]; then
        exec "$REAL_GH" "$@"
    fi

    echo "ERROR: Could not find real gh executable" >&2
    exit 1
fi

# === BLOCKED - Show helpful message ===

echo "" >&2
echo "╔════════════════════════════════════════════════════════════════╗" >&2
echo "║  ❌ BLOCKED: 'gh $cmd${subcmd:+ $subcmd}' is not allowed                          " >&2
echo "╠════════════════════════════════════════════════════════════════╣" >&2
echo "║                                                                ║" >&2
echo "║  Agents have READ-ONLY access to GitHub.                       ║" >&2
echo "║  Use 'coding-done' or 'reviewer-done' for write operations.     ║" >&2
echo "║                                                                ║" >&2
echo "║  ✅ Allowed commands (read-only):                              ║" >&2
echo "║     gh pr view/list/diff/checks/status                         ║" >&2
echo "║     gh issue view/list/status                                  ║" >&2
echo "║     gh repo view/list/clone                                    ║" >&2
echo "║     gh search repos/issues/prs/commits/code                    ║" >&2
echo "║     gh auth status                                             ║" >&2
echo "║                                                                ║" >&2
echo "║  ✅ For completing work:                                       ║" >&2
echo "║     coding-done completed --implementation \"...\" --problems .. ║" >&2
echo "║                                                                ║" >&2
echo "║  ✅ For code review:                                           ║" >&2
echo "║     reviewer-done approved --summary \"...\" --risk low          ║" >&2
echo "║     reviewer-done changes_requested --issues \"...\" --risk med  ║" >&2
echo "║                                                                ║" >&2
echo "╚════════════════════════════════════════════════════════════════╝" >&2
echo "" >&2
exit 1
