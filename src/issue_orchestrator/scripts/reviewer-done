#!/bin/bash
# reviewer-done wrapper - forwards to the orchestrator's venv installation
#
# This script is placed in the scripts directory which gets prepended to PATH
# when agents run. It forwards all arguments to the actual reviewer-done command
# in the orchestrator's venv.

# The scripts directory
SCRIPT_SOURCE="${BASH_SOURCE[0]}"
SCRIPT_DIR="${SCRIPT_SOURCE%/*}"
if [[ "$SCRIPT_DIR" == "$SCRIPT_SOURCE" ]]; then
    SCRIPT_DIR="."
fi
SCRIPT_DIR="$(cd "$SCRIPT_DIR" && pwd)"

source "$SCRIPT_DIR/completion-wrapper-lib.sh"
if REVIEWER_DONE="$(completion_wrapper_resolve "$SCRIPT_DIR" "reviewer-done")"; then
    exec "$REVIEWER_DONE" "$@"
fi

# Fallback: try to find in PATH (if installed globally)
REAL_REVIEWER_DONE=$(which -a reviewer-done 2>/dev/null | grep -v "$SCRIPT_DIR" | head -1)
if [[ -x "$REAL_REVIEWER_DONE" ]]; then
    exec "$REAL_REVIEWER_DONE" "$@"
fi

echo "╔════════════════════════════════════════════════════════════════╗" >&2
echo "║  ❌ ERROR: reviewer-done not found                             ║" >&2
echo "╠════════════════════════════════════════════════════════════════╣" >&2
echo "║                                                                ║" >&2
echo "║  The issue-orchestrator package may not be installed.         ║" >&2
echo "║                                                                ║" >&2
echo "║  Checked locations:                                           ║" >&2
for REVIEWER_DONE in "${completion_candidate_paths[@]}"; do
    echo "║  $REVIEWER_DONE" >&2
done
echo "║                                                                ║" >&2
echo "╚════════════════════════════════════════════════════════════════╝" >&2
exit 1
