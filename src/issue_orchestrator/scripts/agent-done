#!/bin/bash
# agent-done backward-compatibility wrapper → forwards to coding-done.
#
# New code should use coding-done or reviewer-done directly.
# This wrapper exists so agents started with older prompts still work.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# coding-done lives alongside this script in the scripts directory
CODING_DONE="$SCRIPT_DIR/coding-done"

if [[ -x "$CODING_DONE" ]]; then
    exec "$CODING_DONE" "$@"
fi

# Fallback: try coding-done on PATH
if command -v coding-done &>/dev/null; then
    exec coding-done "$@"
fi

echo "ERROR: coding-done not found (agent-done is a backward-compat wrapper)" >&2
exit 1
