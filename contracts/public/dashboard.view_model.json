        },
        "e2eRunning": {
          "title": "E2Erunning",
          "type": "boolean"
        },
        "githubOwner": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Githubowner"
        },
        "githubRepo": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Githubrepo"
        },
        "paused": {
          "title": "Paused",
          "type": "boolean"
        },
        "providerCircuit": {
          "$ref": "#/$defs/ProviderCircuitStatusContract"
        },
        "queueRefreshSeconds": {
          "title": "Queuerefreshseconds",
          "type": "integer"
        },
        "repo": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
