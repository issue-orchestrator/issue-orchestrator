    },
    "paused": {
      "title": "Paused",
      "type": "boolean"
    },
    "shutdown_requested": {
      "title": "Shutdown Requested",
      "type": "boolean"
    },
    "startup_status": {
      "title": "Startup Status",
      "type": "string"
    }
  },
  "required": [
    "dashboard_data",
    "paused",
    "startup_status",
    "active_tab",
    "shutdown_requested"
